# Snowflake connection used by Flask lookup/enrichment and the Parquet loader.
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=GEO
SNOWFLAKE_SCHEMA=OBM

# Optional Snowflake settings.
# SNOWFLAKE_ROLE=your_role
# SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Tables created/read by the app.
SNOWFLAKE_RAW_TABLE=OBM_BUILDINGS_RAW
SNOWFLAKE_BUILDINGS_TABLE=OBM_BUILDINGS

# CARTO connection used by deck.gl VectorTileLayer.
CARTO_ACCESS_TOKEN=your_carto_access_token
CARTO_CONNECTION_NAME=your_carto_snowflake_connection_name
# CARTO_API_BASE_URL=https://gcp-us-east1.api.carto.com

# Optional app defaults.
OBM_PARQUET_PATH=etl_output/buildings_cleaned.parquet
MAP_DEFAULT_LON=10.45
MAP_DEFAULT_LAT=51.16
MAP_DEFAULT_ZOOM=5.4
